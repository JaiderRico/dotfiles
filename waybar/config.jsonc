{
    "layer": "top",
    "position": "top",
    "height": 35,
    "spacing": 8,
    "font-family": "JetBrainsMono Nerd Font",

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock", "custom/notification"],
    "modules-right": [
        "custom/cpu",
        "memory",
        "custom/updates",
        "network",
        "bluetooth",
        "pulseaudio",
        "battery",
        "custom/usb",
        "custom/power"
    ],

    "hyprland/workspaces": {
        "format": "●",
        "sort-by-number": true
    },

    "clock": {
        "format": "  {:%I:%M %p}",
        "tooltip-format": "{:%A, %d de %B de %Y}",
        "on-click": "~/.config/eww/toggle-popup.sh"
    },

    "custom/notification": {
        "format": "{icon}",
        "format-icons": {
            "notification": "󱅫",
            "none": "󰂚",
            "dnd-notification": "󰂰",
            "dnd-none": "󰂰"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb 2>/dev/null || echo '{\"text\":\"3000\",\"alt\":\"none\",\"tooltip\":\"sin gestor de notificaciones\"}'",
        "on-click": "~/.config/eww/toggle-popup.sh",
        "escape": true
    },

    "custom/usb": {
        "return-type": "json",
        "exec": "~/.config/waybar/usb-check.sh",
        "on-click": "~/.config/waybar/usb-eject.sh",
        "escape": true
    },

    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "~/.config/waybar/power-menu.sh"
    },

    "network": {
        "format-wifi": " ",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰖪",
        "tooltip-format": "{essid} - {ipaddr}",
        "on-click": "~/.config/waybar/wifi-menu.sh"
    },

    "bluetooth": {
        "format": "󰂯",
        "format-connected": "󰂱",
        "format-off": "󰂲",
        "tooltip-format": "{controller_alias}",
        "on-click": "~/.config/waybar/bluetooth-menu.sh"
    },

    "pulseaudio": {
        "format": "󰕾 {volume}%",
        "format-muted": "󰖁",
        "tooltip-format": "Volume: {volume}%",
        "on-click": "pavucontrol"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "tooltip-format": "{capacity}% - {time}",
        "states": {
            "warning": 30,
            "critical": 15
        }
    },

    "custom/cpu": {
        "format": "󰻠 {}%",
        "interval": 5,
        "exec": "top -bn1 | grep 'Cpu(s)' | awk '{print $2}' | cut -d'.' -f1",
        "tooltip": true
    },

    "memory": {
        "format": "󰍛 {percentage}%",
        "interval": 5,
        "tooltip-format": "{used:0.1f}GiB / {total:0.1f}GiB"
    },

    "custom/updates": {
        "format": "󰏗 {}",
        "interval": 3600,
        "exec": "checkupdates 2>/dev/null | wc -l",
        "tooltip": true,
        "on-click": "kitty -e sudo pacman -Syu"
    }
}